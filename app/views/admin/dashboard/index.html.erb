<section class="admin-shell">
  <div class="admin-page">
    <header class="admin-hero">
      <div>
        <p class="admin-kicker">Admin Console</p>
        <h1 class="admin-title">Storefront Admin</h1>
        <p class="admin-subtitle">Manage products, vendors, pricing, and orders from one place.</p>
      </div>
    </header>

    <div class="admin-actions">
      <%= link_to new_admin_product_path, class: "admin-action-card" do %>
        <span class="admin-action-kicker">Products</span>
        <h2>Create product</h2>
        <p>Add a new product before uploading images or variants.</p>
        <span class="admin-action-link">Start product →</span>
      <% end %>

      <%= link_to admin_products_path, class: "admin-action-card admin-action-card--accent" do %>
        <span class="admin-action-kicker">Products</span>
        <h2>Manage products</h2>
        <p>Edit details, pricing, and jump into image uploads.</p>
        <span class="admin-action-link">Go to products →</span>
      <% end %>

      <%= link_to new_admin_product_variant_path, class: "admin-action-card admin-action-card--accent" do %>
        <span class="admin-action-kicker">Variants</span>
        <h2>Add product variant</h2>
        <p>Create new sizes or options with stock and pricing overrides.</p>
        <span class="admin-action-link">Open variant form →</span>
      <% end %>

      <%= link_to admin_orders_path, class: "admin-action-card" do %>
        <span class="admin-action-kicker">Orders</span>
        <h2>Review orders</h2>
        <p>Track purchases, totals, and fulfillment status.</p>
        <span class="admin-action-link">Go to orders →</span>
      <% end %>

      <%= link_to admin_vendors_path, class: "admin-action-card admin-action-card--accent" do %>
        <span class="admin-action-kicker">Vendors</span>
        <h2>Manage vendors</h2>
        <p>Track supplier contacts and pricing inputs.</p>
        <span class="admin-action-link">Go to vendors →</span>
      <% end %>

      <%= link_to admin_vendor_products_path, class: "admin-action-card" do %>
        <span class="admin-action-kicker">Vendor pricing</span>
        <h2>Vendor product links</h2>
        <p>Map products to vendor costs and lead times.</p>
        <span class="admin-action-link">Go to vendor pricing →</span>
      <% end %>
    </div>
  </div>
</section>
