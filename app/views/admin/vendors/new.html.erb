<section class="admin-shell">
  <div class="admin-page">
    <header class="admin-hero admin-hero--compact">
      <div>
        <p class="admin-kicker">Vendors</p>
        <h1 class="admin-title">Create vendor</h1>
        <p class="admin-subtitle">Add supplier contact and status details.</p>
      </div>
      <%= link_to "Back to admin", admin_root_path, class: "admin-secondary-link" %>
    </header>

    <%= form_with model: @vendor, url: admin_vendors_path, local: true, html: { class: "admin-form" } do |f| %>
      <div class="admin-form-grid">
        <div class="admin-field">
          <%= f.label :name %>
          <%= f.text_field :name, required: true %>
        </div>

        <div class="admin-field">
          <%= f.label :contact_name, "Primary contact" %>
          <%= f.text_field :contact_name %>
        </div>

        <div class="admin-field">
          <%= f.label :email %>
          <%= f.email_field :email %>
        </div>

        <div class="admin-field">
          <%= f.label :phone %>
          <%= f.telephone_field :phone %>
        </div>

        <div class="admin-field">
          <%= f.label :website %>
          <%= f.url_field :website %>
        </div>

        <div class="admin-field">
          <%= f.label :notes %>
          <%= f.text_area :notes, rows: 4 %>
        </div>
      </div>

      <div class="admin-field admin-field-inline">
        <%= f.check_box :active %>
        <%= f.label :active, "Active" %>
      </div>

      <%= f.submit "Create Vendor", class: "admin-primary-button" %>
    <% end %>
  </div>
</section>
