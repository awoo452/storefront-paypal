<% content_for :disable_turbo, true %>

<% content_for :head do %>
  <meta name="turbo-visit-control" content="reload">
<% end %>

<section class="product-show">
  <div class="product-show-card" data-controller="variant-selector">
    <h1><%= @product.name %></h1>

    <% if @product.image_variant_keys.any? %>
      <% @product.image_variant_keys.each_with_index do |key, index| %>
        <% proxy_url = image_proxy_url(key, width: 900, height: 900, fit: "inside", format: "webp") %>
        <% if proxy_url.present? %>
          <%= image_tag proxy_url,
            class: "product-main-image",
            alt: index.zero? ? @product.name : "#{@product.name} alternate",
            loading: (index.zero? ? "eager" : "lazy") %>
        <% end %>
      <% end %>
    <% else %>
      <%= image_tag "coming-soon.svg",
        class: "product-main-image",
        alt: "Image coming soon",
        loading: "eager" %>
    <% end %>

    <p class="product-description"><%= @product.description %></p>

    <% priced_variants = @variants.select(&:price_available?) %>
    <% available_variants = priced_variants.select { |v| v.stock.present? && v.stock > 0 } %>
    <% selected_variant_id = params[:variant_id].presence %>
    <% selected_variant = @variants.find { |variant| variant.id.to_s == selected_variant_id } %>
    <% default_variant = selected_variant || available_variants.first || priced_variants.first %>
    <% default_price = default_variant&.effective_price || @product.price %>

    <% if @product.price_hidden? %>
      <p class="product-price">Coming Soon</p>
    <% elsif @variants.any? && priced_variants.empty? %>
      <p class="product-price">Pricing pending</p>
    <% elsif @variants.any? && available_variants.empty? %>
      <p class="product-price">Sold Out</p>
    <% elsif @variants.none? %>
      <p class="product-price">No options available</p>
    <% else %>
      <p class="product-price">
        <% if default_price.present? %>
          $<span id="display-price" data-variant-selector-target="price"><%= number_with_precision(default_price, precision: 2) %></span>
        <% else %>
          <span id="display-price" data-variant-selector-target="price">—</span>
        <% end %>
      </p>

      <%= form_with url: items_cart_path,
            method: :post,
            local: true,
            data: { turbo: false },
            html: { class: "variant-selector" } do %>
        <label for="variant_id">Choose option</label>
        <select id="variant_id"
                name="variant_id"
                data-variant-selector-target="select"
                data-action="change->variant-selector#update">
          <option value="" disabled <%= "selected" if selected_variant.nil? %>>Select an option</option>
          <% @variants.each do |variant| %>
            <% out_of_stock = variant.stock.blank? || variant.stock <= 0 %>
            <% price_missing = variant.price_available? == false %>
            <option
              value="<%= variant.id %>"
              data-price="<%= variant.effective_price if variant.price_available? %>"
              <%= "disabled" if out_of_stock || price_missing %>
              <%= "selected" if selected_variant&.id == variant.id %>>
              <%= variant.name %>
              <% if out_of_stock %>
                (Sold out)
              <% elsif price_missing %>
                (Pricing pending)
              <% elsif variant.stock.present? %>
                (<%= variant.stock %> left)
              <% end %>
            </option>
          <% end %>
        </select>

        <%= submit_tag "Add to cart",
              class: "product-cart-button",
              data: { variant_selector_target: "submit" } %>
      <% end %>
    <% end %>

    <%= link_to "Back to products", products_path,
          class: "back-link",
          data: { turbo: false } %>

  </div>
</section>
